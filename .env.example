# Google Service Account - file path or raw JSON content
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json

# Gemini API key for AI summarization (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Gmail SMTP settings
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENT=recipient@example.com

# Email privacy threshold - emails with this many or fewer recipients
# are considered private and excluded from the briefing (default: 3)
# EMAIL_PRIVACY_THRESHOLD=3
